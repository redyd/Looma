<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="avares://Looma.App/Assets/icon.ico"
        xmlns:vm="using:Looma.Presentation.ViewModels.Main"
        x:Class="Looma.Views.Views.Main.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Looma" Width="1024" Height="768">

    <DockPanel>

        <TabControl DockPanel.Dock="Top"
                    SelectedIndex="{Binding SelectedTabIndex}"
                    TabStripPlacement="Top"
                    Margin="20 16 20 0">

            <TabControl.Styles>

                <Style Selector="TabControl > TabStrip">
                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                </Style>

                <Style Selector="TabControl > TabStrip > ItemsPresenter > WrapPanel">
                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                </Style>

                <Style Selector="TabItem">
                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                    <Setter Property="Padding" Value="0 10"/>
                    <Setter Property="Margin" Value="4 0"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="CornerRadius" Value="{StaticResource DefaultCornerRadius}"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Transitions">
                        <Transitions>
                            <BrushTransition Property="Background" Duration="0:0:0.25"/>
                        </Transitions>
                    </Setter>
                    <Setter Property="Template">
                        <ControlTemplate>
                            <Border Background="{TemplateBinding Background}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter Content="{TemplateBinding Header}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter>
                </Style>

                <Style Selector="TabItem:pointerover">
                    <Setter Property="Background" Value="{StaticResource BackgroundHoverBrush}"/>
                </Style>

                <Style Selector="TabItem:selected">
                    <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource TextOnPrimaryBrush}"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Style>

                <Style Selector="TabItem:selected:pointerover">
                    <Setter Property="Background" Value="{StaticResource PrimaryLightBrush}"/>
                </Style>

            </TabControl.Styles>

            <TabControl.ItemContainerTheme>
                <ControlTheme TargetType="TabItem"/>
            </TabControl.ItemContainerTheme>
            
            <TabControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1"/>
                </ItemsPanelTemplate>
            </TabControl.ItemsPanel>

            <TabItem Header="Projets">
                <ContentControl Content="{Binding ProjectsSection.CurrentPage}"/>
            </TabItem>

            <TabItem Header="Stocks">
                <ContentControl Content="{Binding StocksSection.CurrentPage}"/>
            </TabItem>

            <TabItem Header="Patrons">
                <ContentControl Content="{Binding PatternsSection.CurrentPage}"/>
            </TabItem>

            <TabItem Header="Mes documents">
                <ContentControl Content="{Binding DocumentsSection.CurrentPage}"/>
            </TabItem>

        </TabControl>

    </DockPanel>
</Window>