<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Looma.Presentation.ViewModels.Sections.Stocks"
             xmlns:cp="using:Avalonia.Controls"
             x:Class="Looma.Views.Views.Sections.Stocks.WoolFormView"
             x:DataType="vm:WoolFormViewModel">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel HorizontalAlignment="Center"
                    Margin="32"
                    MaxWidth="800">

            <Border Classes="form-container"
                    MaxWidth="800">
                <StackPanel Spacing="0">

                    <!-- En-tête -->
                    <StackPanel Classes="form-header">
                        <TextBlock Classes="form-title"
                                   Text="{Binding Title}"/>
                        <TextBlock Classes="form-subtitle"
                                   Text="Renseignez les informations de la laine"/>
                    </StackPanel>

                    <!-- Section détails -->
                    <Border Classes="form-section">
                        <StackPanel Spacing="0">

                            <TextBlock Classes="section-title" Text="🧶 Détails de la laine"/>

                            <!-- Nom + Marque sur la même ligne -->
                            <Grid ColumnDefinitions="*,16,*" Margin="0 0 0 0">

                                <StackPanel Grid.Column="0" Classes="form-field">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Classes="form-label" Text="Nom"/>
                                        <TextBlock Classes="field-required" Text="*"/>
                                    </StackPanel>
                                    <TextBox Classes="form-input"
                                             Text="{Binding Name}"
                                             Watermark="Ex : Merino Extra Fine"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Classes="form-field">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Classes="form-label" Text="Marque"/>
                                        <TextBlock Classes="field-required" Text="*"/>
                                    </StackPanel>
                                    <TextBox Classes="form-input"
                                             Text="{Binding Brand}"
                                             Watermark="Ex : Drops"/>
                                </StackPanel>

                            </Grid>

                            <!-- Matière + Ratio sur la même ligne -->
                            <Grid ColumnDefinitions="*,16,*">

                                <StackPanel Grid.Column="0" Classes="form-field">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Classes="form-label" Text="Matière"/>
                                        <TextBlock Classes="field-required" Text="*"/>
                                    </StackPanel>
                                    <TextBox Classes="form-input"
                                             Text="{Binding Material}"
                                             Watermark="Ex : Mérinos, Coton, Alpaga..."/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Classes="form-field">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Classes="form-label" Text="Longueur pour 100g"/>
                                        <TextBlock Classes="field-required" Text="*"/>
                                        <TextBlock Classes="form-label" Opacity="0.5" Text="(mètres)"/>
                                    </StackPanel>
                                    <TextBox Classes="form-input"
                                             Text="{Binding LengthToWeightRatioText}"
                                             Watermark="Ex : 200"/>
                                    <TextBlock Classes="form-hint"
                                               Text="Permet de calculer la longueur totale de votre stock"/>
                                </StackPanel>

                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- Section couleur -->
                    <Border Classes="form-section">
                        <StackPanel Spacing="0">

                            <TextBlock Classes="section-title" Text="🎨 Couleur"/>

                            <StackPanel Classes="form-field">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Classes="form-label" Text="Couleur de la laine"/>
                                    <TextBlock Classes="field-required" Text="*"/>
                                </StackPanel>

                                <Border Classes="color-picker-container">
                                    <StackPanel Spacing="12">

                                        <cp:ColorPicker Color="{Binding SelectedColor, Mode=TwoWay}"
                                                        HorizontalAlignment="Stretch"/>

                                        <!-- Prévisualisation -->
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <TextBlock Grid.Column="0"
                                                       Classes="form-hint"
                                                       Text="Aperçu :"
                                                       VerticalAlignment="Center"
                                                       Margin="0"/>
                                            <Border Grid.Column="1"
                                                    Height="32"
                                                    Margin="12 0"
                                                    CornerRadius="6">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding SelectedColor}"/>
                                                </Border.Background>
                                            </Border>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding SelectedColorHex}"
                                                       VerticalAlignment="Center"
                                                       FontSize="11"
                                                       FontFamily="Consolas"
                                                       Classes="form-hint"
                                                       Margin="0"/>
                                        </Grid>

                                    </StackPanel>
                                </Border>
                            </StackPanel>

                        </StackPanel>
                    </Border>

                    <!-- Erreur -->
                    <Border IsVisible="{Binding ErrorMessage,
                                Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Padding="14"
                            Margin="0 0 0 16"
                            CornerRadius="8"
                            Background="#FEF2F2">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="#EF4444"
                                   TextWrapping="Wrap"
                                   FontSize="13"/>
                    </Border>

                    <!-- Boutons -->
                    <StackPanel Classes="form-actions">
                        <Button Classes="form-cancel"
                                Content="Annuler"
                                Command="{Binding CancelCommand}"/>
                        <Button Classes="form-submit"
                                Content="{Binding Title}"
                                Command="{Binding SaveCommand}"/>
                    </StackPanel>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>