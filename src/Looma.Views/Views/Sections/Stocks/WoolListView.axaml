<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Looma.Presentation.ViewModels.Sections.Stocks"
             x:Class="Looma.Views.Views.Sections.Stocks.WoolListView"
             x:DataType="vm:WoolListViewModel">

    <DockPanel Margin="32">

        <!-- Barre de recherche centrée sur 2/3 de la largeur -->
        <Grid DockPanel.Dock="Top" Margin="0 0 0 24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="1"
                     Classes="form-input"
                     Text="{Binding SearchQuery}"
                     Watermark="Rechercher par nom, marque, couleur, matière..."
                     VerticalContentAlignment="Center"/>
        </Grid>

        <!-- Titre + bouton ajouter -->
        <DockPanel 
            DockPanel.Dock="Top" 
            Margin="0 0 0 20"
            HorizontalSpacing="20">
            <TextBlock Text="Mes laines"
                       FontSize="22"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            <Button DockPanel.Dock="Right"
                    Content="+ Ajouter une laine"
                    Command="{Binding OpenAddFormCommand}"
                    Classes="form-submit"/>
        </DockPanel>

        <!-- Pagination bas de page -->
        <Border DockPanel.Dock="Bottom"
                Margin="0 16 0 0"
                Padding="16 10"
                CornerRadius="8"
                Background="{StaticResource BackgroundCardBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Spacing="12">
                <Button Content="←"
                        Command="{Binding PreviousPageCommand}"
                        Classes="form-cancel"
                        Width="36" Height="36"
                        Padding="0"/>
                <TextBlock Text="{Binding PageInfo}"
                           VerticalAlignment="Center"
                           FontSize="14"/>
                <Button Content="→"
                        Command="{Binding NextPageCommand}"
                        Classes="form-cancel"
                        Width="36" Height="36"
                        Padding="0"/>
            </StackPanel>
        </Border>

        <!-- Grille de cartes -->
        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding CurrentPageWools}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:WoolSummary">
                        <Button Command="{Binding $parent[UserControl].DataContext.OpenDetailCommand}"
                                CommandParameter="{Binding}"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand">
                            <Border Width="220"
                                    Margin="8"
                                    Padding="16"
                                    CornerRadius="12"
                                    Background="{StaticResource BackgroundCardBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    BoxShadow="0 2 12 0 #10000000">
                                <Border.Styles>
                                    <Style Selector="Border:pointerover">
                                        <Setter Property="Background" Value="{StaticResource BackgroundHoverBrush}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource PrimaryDarkBrush}"/>
                                    </Style>
                                </Border.Styles>

                                <StackPanel Spacing="8">

                                    <!-- Pastille couleur + nom -->
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Ellipse Width="16" Height="16" VerticalAlignment="Center"
                                                 Fill="{Binding Wool.Color, Converter={StaticResource HexToColor}}" />
                                        <TextBlock Text="{Binding Wool.Name}"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <!-- Marque -->
                                    <TextBlock Text="{Binding Wool.Brand}"
                                               FontSize="12"
                                               Opacity="0.6"/>

                                    <!-- Matière + couleur -->
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Border Padding="6 2" CornerRadius="4"
                                                Background="{StaticResource BackgroundBrush}"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1">
                                            <TextBlock Text="{Binding Wool.Material}" FontSize="11"/>
                                        </Border>
                                        <Border Padding="6 2" CornerRadius="4"
                                                Background="{StaticResource BackgroundBrush}"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1">
                                            <TextBlock Text="{Binding Wool.Color}" FontSize="11"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- Séparateur -->
                                    <Border Height="1"
                                            Background="{StaticResource BorderBrush}"
                                            Opacity="0.5"
                                            Margin="0 2 0 2"/>

                                    <!-- Stock + ratio -->
                                    <Grid ColumnDefinitions="*,*">
                                        <StackPanel Grid.Column="0" Spacing="2">
                                            <TextBlock Text="Stock" FontSize="10" Opacity="0.5"/>
                                            <StackPanel Orientation="Horizontal" Spacing="3">
                                                <TextBlock Text="{Binding TotalWeightGrams, StringFormat='{}{0:N0}'}"
                                                           FontSize="13" FontWeight="SemiBold"/>
                                                <TextBlock Text="g" FontSize="11" Opacity="0.5"
                                                           VerticalAlignment="Bottom" Margin="0 0 0 1"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="Ratio" FontSize="10" Opacity="0.5"/>
                                            <StackPanel Orientation="Horizontal" Spacing="3">
                                                <TextBlock Text="{Binding Wool.LengthToWeightRatio}"
                                                           FontSize="13" FontWeight="SemiBold"/>
                                                <TextBlock Text="m/100g" FontSize="11" Opacity="0.5"
                                                           VerticalAlignment="Bottom" Margin="0 0 0 1"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>

                                </StackPanel>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</UserControl>